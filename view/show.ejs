<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Show Post</title>
    <link rel="stylesheet" href="/show.css">
</head>

<body>
    <div class="container">
        <h2>Here is your Post</h2>
        <p> Post Id : <%= post.id%>
        </p>
        <div class="post">
            <h2 class="username">@<%= post.username %>
            </h2>
            <h3>
                <%= post.content %>
            </h3>
        </div>
    </div>

</body>

</html>